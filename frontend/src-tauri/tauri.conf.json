{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OffGuard",
  "version": "0.1.0",
  "identifier": "com.outliers.offguard",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OffGuard - Secure Session",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": true,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; media-src * blob: data: asset: http://asset.localhost_*; img-src * blob: data: asset: http://asset.localhost_*; connect-src *"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.macOS.plist",
      "infoPlist": "Info.plist"
    }
  }
}