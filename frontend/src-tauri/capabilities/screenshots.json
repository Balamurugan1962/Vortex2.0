{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "screenshots-capability",
    "description": "Capability to allow checking screens and capturing the full monitor.",
    "windows": [
        "*"
    ],
    "permissions": [
        "screenshots:default",
        "fs:default",
        {
            "identifier": "fs:allow-read-file",
            "allow": [
                {
                    "path": "**"
                }
            ]
        }
    ]
}